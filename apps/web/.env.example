# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
ANTHROPIC_API_KEY=
# Optional: override default model (defaults to claude-sonnet-4.5)
AI_MODEL=

# Admin
# Email address of the single admin user (must match a Supabase auth user)
ADMIN_EMAIL=
# Static API key for machine-to-machine endpoints (e.g. /api/admin/sms-usage)
ADMIN_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clinic
# Optional: display name shown in AI prompts (defaults to V-Health)
CLINIC_NAME=

# Reports
# Secret used to sign and verify JWT report tokens
REPORT_TOKEN_SECRET=

# Cron jobs — set by Vercel, or manually for local testing
CRON_SECRET=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Upstash Redis (SMS rate limiting — optional in local dev, required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Email alerts (optional — used by SMS cost alert cron)
# Sign up at https://resend.com — free tier covers low-volume alerts
RESEND_API_KEY=

# Widget
# Anthropic API key scoped to the public chatbot widget (separate from main ANTHROPIC_API_KEY)
ANTHROPIC_API_KEY_WIDGET=
# Cloudflare Turnstile (bot protection on widget session creation)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Clinic email address to receive widget lead notifications
WIDGET_CLINIC_EMAIL=
# Symmetric secret used to sign short-lived widget session JWTs (must be >=32 chars)
WIDGET_SESSION_SECRET=
