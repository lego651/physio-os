# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-your-api-key
AI_MODEL=claude-sonnet-4-20250514

# App config
CLINIC_NAME=V-Health
ADMIN_EMAIL=admin@your-clinic.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Default clinic for new SMS patients (will be replaced by Twilio-number-to-clinic mapping)
DEFAULT_CLINIC_ID=vhealth

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Upstash Redis (for SMS rate limiting in production — optional for local dev)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
