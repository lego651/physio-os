# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-your-api-key
AI_MODEL=claude-sonnet-4-20250514

# App config
CLINIC_NAME=V-Health
ADMIN_EMAIL=admin@your-clinic.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (transactional email — used for emergency alert notifications)
RESEND_API_KEY=re_your-resend-api-key
# Default clinic for new SMS patients (will be replaced by Twilio-number-to-clinic mapping)
DEFAULT_CLINIC_ID=vhealth

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Cron job authentication (Vercel Cron passes this as Bearer token)
CRON_SECRET=your-cron-secret

# JWT signing secret for weekly report tokens (min 32 chars)
REPORT_TOKEN_SECRET=your-report-token-secret-min-32-chars

# Admin API key for internal endpoints (e.g. /api/admin/sms-usage)
ADMIN_API_KEY=your-admin-api-key

# Upstash Redis (for SMS rate limiting in production — optional for local dev)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Widget (public chatbot)
WIDGET_ENABLED=true
ANTHROPIC_API_KEY_WIDGET=               # dedicated Anthropic key with $10 lifetime cap
TURNSTILE_SITE_KEY=                     # Cloudflare Turnstile site key (client)
TURNSTILE_SECRET_KEY=                   # Cloudflare Turnstile secret (server verify)
WIDGET_CLINIC_EMAIL=vhealthc@gmail.com  # lead notification recipient
WIDGET_DAILY_SPEND_ALERT_USD=2          # alert Jason if daily spend > this
